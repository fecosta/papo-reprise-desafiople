          "_name": "header01",
          "_sourceTheme": "nichem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"nichem5 header1\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\" checked>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"15\" step=\"1\" value=\"15\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"15\" step=\"1\" value=\"15\" condition=\"fullScreen == false\">\n\n        <input type=\"range\" inline name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value>Left</option>\n            <option value=\"justify-content-center\" selected>Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/teacher.jpg-1560x1040.jpeg\">\n            <input type=\"color\" title=\"Color\" value=\"#6500e0\">\n            <input type=\"video\" title=\"Video\" value=\"https://espacoaquarius.com.br/desafiople.mp4\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#17003b\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <svg xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" width=\"1080\" height=\"253.82014\" viewBox=\"0 0 1080 253.82014\">\n        <defs>\n            <style>\n                .fdeb5a33-207d-40f6-bc48-29f0c4647cbd {\n                    fill: #17003b\n                }\n            </style>\n        </defs>\n        <g id=\"af7dea71-9c11-4d01-a36a-129359a5a3d7\" data-name=\"Layer 2\">\n            <g class=\"f1331eda-9bb9-469e-a57d-15137ea43ac8\" id=\"ef9d1827-b12c-450a-85ff-628f7219c5fe\" data-name=\"Layer 1\">\n                <g id=\"b117b6df-8698-4da4-b528-9e75cef1499b\" data-name=\"Group 6802\">\n                    <path id=\"bf8ed394-4aff-4bf9-89b5-fb26e8fb9263\" data-name=\"Path 1703\" class=\"fdeb5a33-207d-40f6-bc48-29f0c4647cbd\" d=\"M1080,0c-54.422,185.051-382.112,379.242-787.231,148.813C51.24,11.433,0,0,0,0Z\"></path>\n                </g>\n            </g>\n        </g>\n    </svg>\n\n    <div class mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row {{contentAlign}}\">\n            <div class=\"col-12 col-lg-{{textWidth}}\">\n               \n                <h1 class=\"mbr-section-title mbr-fonts-style mb-5\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><div><br></div>&nbsp;<i>de 23/04 a 30/04</i></h1>\n\n               \n                <h1 class=\"mbr-section-title mbr-fonts-style mb-5\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><div><br></div><br><div><br></div><div><a href=\"#\" class=\"text-white\" style><br></a></div><div><a href=\"#\" class=\"text-white\" style>&nbsp;Desafio Ensine PLE&nbsp;</a>&nbsp;</div><br><div><a href=\"#\" class=\"text-white\" style><br></a></div><div>Semana de formação <br>gratuita e super prática!</div></h1>\n\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\"><span style=\"font-weight: normal;\"><a href=\"index.html\" class=\"text-white\" style><br></a></span><br></p>\n                <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\"><a class=\"btn btn-lg btn-primary\" href=\"index.html#custom-html-s\" data-app-placeholder=\"Type Text\">QUERO PARTICIPAR DO DESAFIO</a></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_cid": "vgq3iQsevG",
          "_anchor": "header01-1t",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "@keyframes wave2": {
              "0%": {
                "transform": "scaleY(0.8)"
              },
              "50%": {
                "transform": "scaleY(1)"
              },
              "100%": {
                "transform": "scaleY(0.8)"
              }
            },
            "#gentle-wave": {
              "fill": "@bg-value"
            },
            ".svg2": {
              "background": "transparent",
              "position": "absolute",
              "bottom": "100%",
              "animation": "5s ease infinite wave2",
              "transform": "scaleY(0.8)",
              "transform-origin": "bottom"
            },
            "b": {
              "font-weight": "900"
            },
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            "img": {
              "@media (min-width: 992px)": {
                "padding": "0 4rem"
              },
              "@media (max-width: 992px)": {
                "padding-bottom": "2rem"
              }
            },
            "@keyframes wave1": {
              "0%": {
                "left": "-30%"
              },
              "100%": {
                "left": "-1%"
              }
            },
            ".link-wrapper": {
              "width": "fit-content",
              "position": "relative",
              "display": "inline-block",
              "overflow": "hidden",
              "cursor": "pointer",
              "padding-bottom": "10px",
              ".svg1": {
                "position": "absolute",
                "top": "60%",
                "width": "130%",
                "min-width": "300px",
                "left": "-30%",
                "height": "auto",
                "path": {
                  "stroke": "currentColor !important"
                }
              },
              "&:hover": {
                ".svg1": {
                  "animation": "1s linear forwards infinite wave1"
                }
              }
            },
            ".row": {
              "align-items": "center"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#ffffff"
            },
            ".mbr-link, .link-wrapper": {
              "color": "#ffffff"
            }
          },
          "_name": "article01",
          "_sourceTheme": "nichem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"nichem5 article1\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline name=\"imageWidth\" title=\"Image\" min=\"4\" max=\"8\" step=\"1\" value=\"6\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\" checked>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#6500e0\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n\n\n    <svg class=\"svg2\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" viewBox=\"0 24 150 28\" preserveAspectRatio=\"none\" shape-rendering=\"auto\">\n        <defs>\n            <path id=\"gentle-wave\" d=\"M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z\"></path>\n        </defs>\n        <g>\n            <use xlink:href=\"#gentle-wave\" x=\"48\" y=\"0\"></use>\n        </g>\n    </svg>\n\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-12 col-lg-{{imageWidth}} image-wrapper\">\n                <img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/screenshot-2025-05-30-at-21.08.06.png-1920x1080.png-820x461.png\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"col-12 col-md-12 col-lg\">\n                <div class=\"text-wrapper align-left\">\n                    <h1 class=\"mbr-section-title mbr-fonts-style align-left mb-3\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"></h1>\n                    <p class=\"mbr-text mbr-fonts-style align-left\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">Prepare-se para uma semana de formação gratuita e super prática, focada em transformar o modo como você dá aulas de português como língua estrangeira. Ao se inscrever no Desafio Ensine PLE, você terá 7 dias de acesso liberado à plataforma de recursos didáticos Portuguese4You, com materiais prontos para diferentes níveis e fins específicos — tudo digital, interativo e pronto para aplicar.<br><br>Durante essa jornada, vamos direto ao ponto: como dar aulas de português adaptadas a diferentes perfis (negócios, viagens, geral) e objetivos dos alunos (gramática, compreensão auditiva, gêneros discursivos), com clareza, estrutura e economia de tempo. E para fechar com chave de ouro, você participa de um aulão ao vivo sobre como tornar seu trabalho como professora de PLE mais lucrativo, valorizando seu tempo e sua experiência.<br></p>\n                    <div class=\"link-wrapper align-left\">\n                        <p class=\"mbr-link align-left mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showButtons\" data-app-selector=\".mbr-link, .text-wrapper, path\"><b>quero participar</b></p>\n\n\n                        <svg class=\"svg1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" version=\"1.1\" width=\"300\" height=\"50\" viewBox=\"0 0 300 50\" preserveAspectRatio=\"xMidYMid slice\" xml:space=\"preserve\">\n                            <defs>\n                            </defs>\n                            <g transform=\"matrix(1 0 0 1 200 4.59)\">\n                                <g style>\n                                    <g transform=\"matrix(1 0 0 1 -125 0)\" id=\"aac4a38b-7b64-4b27-81f4-7cba1fc44311\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-75, -4.59)\" d=\"M 100 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 87.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 50 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 75 0)\" id=\"bdacfd93-3ab9-4965-b36c-24275b9d80d7\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-275, -4.59)\" d=\"M 300 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 287.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 250 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 -175 0)\" id=\"fa02ee22-c807-4234-a62a-6ef55f12a121\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-25, -4.59)\" d=\"M 50 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 37.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 0 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 -25 0)\" id=\"f5eeec8a-c1c0-4e31-b653-6adc33e4b3e8\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-175, -4.59)\" d=\"M 200 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 187.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 150 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 125 0)\" id=\"b51bbcd5-3066-47f5-8b80-6fd345774dc4\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-325, -4.59)\" d=\"M 350 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 337.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 300 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 175 0)\" id=\"a258efd3-c8f0-4dd9-8a96-69ce4b07fe50\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-375, -4.59)\" d=\"M 400 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 387.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 350 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 -75 0)\" id=\"b55a1ba9-a72e-4a0e-ba97-85e004b73874\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-125, -4.59)\" d=\"M 150 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 137.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 100 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 25 0)\" id=\"ac2b4d02-8806-4f29-a2a5-1942e82a5fe8\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-225, -4.59)\" d=\"M 250 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 237.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 200 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                </g>\n                            </g>\n                        </svg>\n\n                    </div>\n\n\n\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vgq3iQQCbL",
