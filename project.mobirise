                  "margin-bottom": "54px",
                  "@media (max-width: 992px)": {
                    "width": "100%",
                    "margin-bottom": "24px"
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#f5f8ff"
            },
            ".mbr-label": {
              "color": "#f5f8ff",
              "text-align": "center"
            },
            ".mbr-section-title, .title-wrapper, .mbr-section-btn": {
