        {
          "_name": "article05",
          "_sourceTheme": "glancem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article01 glancem5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"3\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"3\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Main Border\" name=\"showMainBorder\">\n        <input type=\"color\" title=\"Border Color\" value=\"#ffffff\" name=\"mainBorder\" condition=\"showMainBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/glancem5/components/_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#6500e0\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/glancem5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"title-wrapper\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn, .title-wrapper\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">\n                            Marketing Evolution 2030: Breakthrough Strategies, AI-Powered Innovations, and Proven Growth\n                            Tactics to Elevate Your Brand and Dominate the Digital Landscape\n                        </h2>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"index.html#custom-html-s\" data-app-placeholder=\"Type Text\">QUERO PARTICIPAR DO DESAFIO</a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@showMainBorder)": {
              "border-bottom": "2px solid @mainBorder"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "padding": "0 108px",
              "@media (max-width: 1440px)": {
                "padding": "0 64px"
              },
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              ".title-wrapper": {
                ".mbr-section-title": {
                  "display": "inline-block",
                  "width": "70%",
                  "margin-bottom": "54px",
                  "@media (max-width: 992px)": {
                    "width": "100%",
                    "margin-bottom": "22px"
                  }
                }
              }
            },
            ".mbr-section-title, .title-wrapper": {
              "color": "#ffffff"
            },
            ".mbr-section-title, .mbr-section-btn, .title-wrapper": {
              "text-align": "center"
            }
          },
          "_cid": "vgq3iRaJg3",
          "_anchor": "article05-1v",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "@keyframes wave1": {
              "0%": {
                "left": "-30%"
              },
              "100%": {
                "left": "-1%"
              }
            },
            "b, strong": {
              "font-weight": "900"
            },
            "& when (@reverseContent)": {
              ".row": {
                "flex-direction": "row-reverse"
              }
            },
            "img": {
              "@media (min-width: 992px)": {
                "padding": "0 4rem"
              },
              "@media (max-width: 992px)": {
                "padding-bottom": "2rem"
              }
            },
            ".link-wrapper": {
              "width": "fit-content",
              "position": "relative",
              "display": "inline-block",
              "overflow": "hidden",
              "cursor": "pointer",
              "padding-bottom": "10px",
              ".svg1": {
                "position": "absolute",
                "top": "60%",
                "width": "130%",
                "min-width": "300px",
                "left": "-30%",
                "height": "auto",
                "path": {
                  "stroke": "currentColor !important"
                }
              },
              "&:hover": {
                ".svg1": {
                  "animation": "1s linear forwards infinite wave1"
                }
              }
            },
            ".row": {
              "align-items": "center"
            },
            ".mbr-section-title": {
              "color": "#17003b"
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#ffffff"
            },
            ".mbr-link, .link-wrapper": {
              "color": "#ffffff"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#17003b"
            },
            ".mbr-link, .text-wrapper, path": {
              "color": "#17003b"
            }
          },
          "_name": "article03",
          "_sourceTheme": "nichem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"nichem5 article3\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"7\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline name=\"imageWidth\" title=\"Image\" min=\"4\" max=\"8\" step=\"1\" value=\"7\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#f5f5f5\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-12 col-lg-{{imageWidth}} image-wrapper\">\n                <img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/mbr-3.jpeg\" alt=\"Mobirise Website Builder\">\n            </div>\n            <div class=\"col-12 col-md-12 col-lg\">\n                <div class=\"text-wrapper align-left\">\n                    <h1 class=\"mbr-section-title mbr-fonts-style align-left mb-4\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\"><b>O que é?</b></h1>\n                    <p class=\"mbr-text mbr-fonts-style align-left pb-3\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .text-wrapper\">Uma semana gratuita de formação prática;<br><br>Acesso liberado por 7 dias à plataforma de recursos didáticos de PLE <i>Portuguese4You</i>;<br><br>Foco em como dar aulas de português para diferentes perfis e objetivos dos alunos;<br><br>Aulão ao vivo sobre como tornar o trabalho da profe mais lucrativo.<br></p>\n                    <div class=\"link-wrapper align-left\">\n                        <p class=\"mbr-link align-left mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showButtons\" data-app-selector=\".mbr-link, .text-wrapper, path\"><b>READ MORE</b></p>\n\n\n                        <svg class=\"svg1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" version=\"1.1\" width=\"300\" height=\"50\" viewBox=\"0 0 300 50\" preserveAspectRatio=\"xMidYMid slice\" xml:space=\"preserve\">\n                            <defs>\n                            </defs>\n                            <g transform=\"matrix(1 0 0 1 200 4.59)\">\n                                <g style>\n                                    <g transform=\"matrix(1 0 0 1 -125 0)\" id=\"aac4a38b-7b64-4b27-81f4-7cba1fc44311\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-75, -4.59)\" d=\"M 100 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 87.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 50 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 75 0)\" id=\"bdacfd93-3ab9-4965-b36c-24275b9d80d7\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-275, -4.59)\" d=\"M 300 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 287.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 250 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 -175 0)\" id=\"fa02ee22-c807-4234-a62a-6ef55f12a121\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-25, -4.59)\" d=\"M 50 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 37.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 0 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 -25 0)\" id=\"f5eeec8a-c1c0-4e31-b653-6adc33e4b3e8\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-175, -4.59)\" d=\"M 200 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 187.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 150 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 125 0)\" id=\"b51bbcd5-3066-47f5-8b80-6fd345774dc4\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-325, -4.59)\" d=\"M 350 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 337.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 300 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 175 0)\" id=\"a258efd3-c8f0-4dd9-8a96-69ce4b07fe50\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-375, -4.59)\" d=\"M 400 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 387.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 350 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 -75 0)\" id=\"b55a1ba9-a72e-4a0e-ba97-85e004b73874\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-125, -4.59)\" d=\"M 150 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 137.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 100 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                    <g transform=\"matrix(1 0 0 1 25 0)\" id=\"ac2b4d02-8806-4f29-a2a5-1942e82a5fe8\">\n                                        <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-225, -4.59)\" d=\"M 250 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 237.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 200 2\" stroke-linecap=\"round\"></path>\n                                    </g>\n                                </g>\n                            </g>\n                        </svg>\n\n                    </div>\n\n\n\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vgq3iRoiKb",
          "_anchor": "article03-1w",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "article05",
          "_sourceTheme": "glancem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article01 glancem5\" group=\"Article\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"3\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Main Border\" name=\"showMainBorder\">\n        <input type=\"color\" title=\"Border Color\" value=\"#ffffff\" name=\"mainBorder\" condition=\"showMainBorder\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/glancem5/components/_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#f5f5f5\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/glancem5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"col-12\">\n                <div class=\"content-wrapper\">\n                    <div class=\"title-wrapper\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .mbr-section-btn, .title-wrapper\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\">\n                            Marketing Evolution 2030: Breakthrough Strategies, AI-Powered Innovations, and Proven Growth\n                            Tactics to Elevate Your Brand and Dominate the Digital Landscape\n                        </h2>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-7\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-secondary\" href=\"index.html#custom-html-s\" data-app-placeholder=\"Type Text\">QUERO PARTICIPAR DO DESAFIO</a></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@showMainBorder)": {
              "border-bottom": "2px solid @mainBorder"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".content-wrapper": {
              "padding": "0 108px",
              "@media (max-width: 1440px)": {
                "padding": "0 64px"
              },
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              ".title-wrapper": {
                ".mbr-section-title": {
                  "display": "inline-block",
                  "width": "70%",
                  "margin-bottom": "54px",
                  "@media (max-width: 992px)": {
                    "width": "100%",
                    "margin-bottom": "22px"
                  }
                }
              }
            },
            ".mbr-section-title, .title-wrapper": {
              "color": "#ffffff"
            },
            ".mbr-section-title, .mbr-section-btn, .title-wrapper": {
              "text-align": "center"
            }
          },
          "_cid": "vgq3iRFbAa",
          "_anchor": "article05-1x",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card": {
              "justify-content": "flex-end"
            },
            ".title-wrapper": {
              "margin-bottom": "40px",
              "@media (max-width: 992px)": {
                "margin-bottom": "20px"
              },
              ".mbr-tag": {
                "margin-bottom": "16px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              }
            },
            ".mbr-section-btn": {
              "margin-bottom": "40px",
              ".btn": {
                "&::after, &::before": {
                  "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)"
                },
                "&:hover, &:focus": {
                  "&::after": {
                    "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)",
                    "opacity": "1"
                  },
                  "color": "@activeBtn !important"
                }
              }
            },
            ".items-wrapper": {
              "margin": "0 -20px",
              ".item": {
                "margin-bottom": "40px",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "20px"
                },
                ".item-wrapper": {
                  "position": "relative",
                  "height": "100%",
                  "padding": "64px 40px 90px 40px",
                  "background-color": "@cardBg",
                  "@media (max-width: 992px)": {
                    "padding": "20px 20px 90px 20px"
                  },
                  ".icon-card": {
                    "position": "absolute",
                    "right": "0",
                    "bottom": "0",
                    "padding": "10px 0 0 10px",
                    "background-color": "@iconBg_2",
                    "border-radius": "25px 0 23px 0",
                    "z-index": "2",
                    ".mbr-iconfont": {
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "width": "50px",
                      "height": "50px",
                      "min-width": "50px",
                      "font-size": "16px",
                      "background-color": "@iconBg_1",
                      "color": "@icon",
                      "border-radius": "100%",
                      "transition": "all .3s ease"
                    },
                    "&:hover, &:focus": {
                      ".mbr-iconfont": {
                        "background-color": "@activeBg",
                        "transform": "rotate(180deg)"
                      }
                    },
                    ".svg1": {
                      "position": "absolute",
                      "top": "-29px",
                      "right": "0px",
                      "transform": "rotate(180deg)",
                      "width": "30px",
                      "path": {
                        "fill": "@iconBg_2"
                      }
                    },
                    ".svg2": {
                      "position": "absolute",
                      "transform": "rotate(180deg)",
                      "width": "30px",
                      "bottom": "0",
                      "left": "-29px",
                      "path": {
                        "fill": "@iconBg_2"
                      }
                    }
                  },
                  ".item-content": {
                    "position": "relative",
                    "z-index": "2",
                    ".item-title": {
                      "margin-bottom": "40px",
                      "@media (max-width: 992px)": {
                        "margin-bottom": "20px"
                      }
                    },
                    ".item-number": {
                      "color": "transparent",
                      "-webkit-background-clip": "text",
                      "background-color": "@number_2",
                      "-webkit-text-fill-color": "@number_1",
                      "-webkit-text-stroke": "2px transparent",
                      "-webkit-text-stroke-width": "4px",
                      "text-stroke": "1px transparent",
                      "margin-bottom": "0"
                    },
                    ".desc-wrapper": {
                      ".item-desc": {
                        "display": "inline-block",
                        "width": "60%",
                        "margin-bottom": "0",
                        "@media (max-width: 1440px)": {
                          "width": "70%"
                        },
                        "@media (max-width: 992px)": {
                          "width": "100%"
                        }
                      }
                    },
                    ".item-btn": {
                      "margin-top": "40px",
                      "margin-bottom": "0",
                      "@media (max-width: 992px)": {
                        "margin-top": "20px",
                        "margin-bottom": "0"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-tag": {
              "color": "#adadad"
            },
            ".item-title": {
              "color": "#ffffff"
            },
            ".item-number": {
              "color": "#2c2c2c",
              "text-align": "right"
            },
            ".item-desc, .desc-wrapper": {
              "color": "#ffffff",
              "text-align": "left"
            },
            ".main-btn": {
              "text-align": "right"
            }
          },
          "_name": "features02",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features02 neuralm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Tag\" name=\"showTag\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\">\n        <input type=\"checkbox\" title=\"Card Number\" name=\"showNumber\">\n        <input type=\"color\" title=\"Number Color 1\" value=\"#2c2c2c\" name=\"number_1\" condition=\"showNumber\">\n        <input type=\"color\" title=\"Number Color 2\" value=\"#ffffff\" name=\"number_2\" condition=\"showNumber\">\n        <input type=\"checkbox\" title=\"Card Description\" name=\"showDesc\" checked>\n        <input type=\"color\" title=\"Card BG\" value=\"#6500e0\" name=\"cardBg\">\n        <header>Icon</header>\n        <input type=\"checkbox\" title=\"Card Icon\" name=\"showIcon\">\n        <input type=\"color\" title=\"Icon Color\" value=\"#ffffff\" name=\"icon\" condition=\"showIcon\">\n        <input type=\"color\" title=\"Icon BG 1\" value=\"#2c2c2c\" name=\"iconBg_1\" condition=\"showIcon\">\n        <input type=\"color\" title=\"Icon BG 2\" value=\"#121212\" name=\"iconBg_2\" condition=\"showIcon\">\n        <input type=\"color\" title=\"Icon Active Color\" value=\"#e24c4a\" name=\"activeBg\" condition=\"showIcon\">\n        <header>Buttons</header>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Card Buttons\" name=\"showCardButtons\">\n        <input type=\"color\" title=\"Button Gradient 1\" value=\"#386bb7\" name=\"gradient_1\" condition=\"showButtons || showCardButtons\" selected>\n        <input type=\"color\" title=\"Button Gradient 2\" value=\"#e24c4a\" name=\"gradient_2\" condition=\"showButtons || showCardButtons\" selected>\n        <input type=\"color\" title=\"Button Active Color\" value=\"#ffffff\" name=\"activeBtn\" condition=\"showButtons || showCardButtons\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/neuralm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#17003b\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/neuralm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#121212\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"title-wrapper\" mbr-if=\"showTitle || showTag\">\n                    <h3 class=\"mbr-tag mbr-fonts-style\" data-app-selector=\".mbr-tag\" mbr-theme-style=\"display-4\" mbr-if=\"showTag\">\n                        / <span> ai marketing</span> /\n                    </h3>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .main-btn\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Motivos para participar</b></h2>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6 card\">\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn main-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                    <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                        View all\n                    </a>\n                </div>\n            </div>\n        </div>\n        <div class=\"row items-wrapper\">\n            <div class=\"item features-without-image col-12 col-lg-4\">\n                <div class=\"item-wrapper\">\n                    <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                        <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                        <a href=\"#\"><span mbr-icon class=\"mbr-iconfont mobi-mbri-arrow-next mobi-mbri\"></span></a>\n                        <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                    </div>\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">\n                            Increase in Engagement\n                        </h4>\n                        <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number\">\n                            <b>30%</b>\n                        </p>\n                        <div class=\"desc-wrapper\">\n                            <p class=\"item-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\" data-app-selector=\".item-desc, .desc-wrapper\">Descobrir como planejar menos e ensinar melhor;<br></p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-without-image col-12 col-lg-4\">\n                <div class=\"item-wrapper\">\n                    <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                        <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                        <a href=\"#\"><span mbr-icon class=\"mbr-iconfont mobi-mbri-arrow-next mobi-mbri\"></span></a>\n                        <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                    </div>\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">\n                            Faster Campaign\n                        </h4>\n                        <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number\">\n                            <b>40%</b>\n                        </p>\n                        <div class=\"desc-wrapper\">\n                            <p class=\"item-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\" data-app-selector=\".item-desc, .desc-wrapper\">\n                                Ter acesso a materiais prontos para vários níveis e focos (negócios, viagem, amor, etc.);\n                            </p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"item features-without-image col-12 col-lg-4\">\n                <div class=\"item-wrapper\">\n                    <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                        <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                        <a href=\"#\"><span mbr-icon class=\"mbr-iconfont mobi-mbri-arrow-next mobi-mbri\"></span></a>\n                        <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                    </div>\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">\n                            Higher Conversion\n                        </h4>\n                        <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number\">\n                            <b>25%</b>\n                        </p>\n                        <div class=\"desc-wrapper\">\n                            <p class=\"item-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\" data-app-selector=\".item-desc, .desc-wrapper\">\n                                Conhecer os principais erros de professores de PLE (e como fugir deles!);\n                            </p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div><div class=\"item features-without-image col-12 col-lg-4\">\n                <div class=\"item-wrapper\">\n                    <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                        <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                        <a href=\"#\"><span mbr-icon class=\"mbr-iconfont mobi-mbri-arrow-next mobi-mbri\"></span></a>\n                        <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                    </div>\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">\n                            Higher Conversion\n                        </h4>\n                        <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number\">\n                            <b>25%</b>\n                        </p>\n                        <div class=\"desc-wrapper\">\n                            <p class=\"item-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\" data-app-selector=\".item-desc, .desc-wrapper\">\n                                Aprender a ensinar compreensão oral e leitora, gramática e gêneros discursivos;\n                            </p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div><div class=\"item features-without-image col-12 col-lg-4\">\n                <div class=\"item-wrapper\">\n                    <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                        <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                        <a href=\"#\"><span mbr-icon class=\"mbr-iconfont mobi-mbri-arrow-next mobi-mbri\"></span></a>\n                        <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                    </div>\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">\n                            Higher Conversion\n                        </h4>\n                        <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number\">\n                            <b>25%</b>\n                        </p>\n                        <div class=\"desc-wrapper\">\n                            <p class=\"item-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\" data-app-selector=\".item-desc, .desc-wrapper\">\n                                Economizar muitas horas de trabalho durante uma semana;\n                            </p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div><div class=\"item features-without-image col-12 col-lg-4\">\n                <div class=\"item-wrapper\">\n                    <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                        <svg class=\"svg1\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                        <a href=\"#\"><span mbr-icon class=\"mbr-iconfont mobi-mbri-arrow-next mobi-mbri\"></span></a>\n                        <svg class=\"svg2\" viewBox=\"0 0 100 100\">\n                            <path d=\"m100,0H0v100C0,44.77,44.77,0,100,0Z\"></path>\n                        </svg>\n                    </div>\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn\">\n                            Higher Conversion\n                        </h4>\n                        <p class=\"item-number mbr-fonts-style\" mbr-theme-style=\"display-1\" mbr-if=\"showNumber\" data-app-selector=\".item-number\">\n                            <b>25%</b>\n                        </p>\n                        <div class=\"desc-wrapper\">\n                            <p class=\"item-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showDesc\" data-app-selector=\".item-desc, .desc-wrapper\">\n                                Aprender a tornar suas aulas mais lucrativas.\n                            </p>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vgq3iRVVhD",
          "_anchor": "features02-1y",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card": {
              "justify-content": "flex-end"
            },
            ".title-wrapper": {
              "margin-bottom": "40px",
              ".mbr-tag": {
                "margin-bottom": "16px"
              },
              ".mbr-section-title": {
                "margin-bottom": "0"
              }
            },
            ".mbr-section-btn": {
              "margin-bottom": "40px",
              ".btn": {
                "&::after, &::before": {
                  "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)"
                },
                "&:hover, &:focus": {
                  "&::after": {
                    "background-image": "linear-gradient(90deg, @gradient_1, @gradient_2 150%)",
                    "opacity": "1"
                  },
                  "color": "@activeBtn !important"
                }
              }
            },
            ".items-wrapper": {
              "margin": "0 -20px",
              ".item": {
                "margin-bottom": "40px",
                "padding": "0 20px",
                "@media (max-width: 992px)": {
                  "margin-bottom": "20px"
                },
                ".item-wrapper": {
                  "position": "relative",
                  "height": "100%",
                  ".item-content": {
                    ".item-title": {
                      "margin-bottom": "16px"
                    },
                    ".item-text": {
                      "margin-bottom": "16px"
                    },
                    ".icon-wrapper": {
                      "margin-top": "32px",
                      "@media (max-width: 992px)": {
                        "margin-top": "20px"
                      },
                      ".icon-wrap": {
                        "display": "inline-flex",
                        "align-items": "center",
                        "justify-content": "center",
                        "width": "56px",
                        "height": "56px",
                        "min-width": "56px",
                        "border-radius": "16px",
                        "background-color": "@iconBg",
                        ".mbr-iconfont": {
                          "color": "transparent",
                          "-webkit-background-clip": "text",
                          "-webkit-text-fill-color": "transparent",
                          "background-image": "linear-gradient(90deg, @icon_1, @icon_2)",
                          "font-size": "32px"
                        }
                      }
                    },
                    ".item-btn": {
                      "margin-top": "40px",
                      "margin-bottom": "0",
                      "@media (max-width: 992px)": {
                        "margin-top": "20px",
                        "margin-bottom": "0"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-tag": {
              "color": "#ffffff"
            },
            ".item-title": {
              "color": "#ffffff"
            },
            ".item-text": {
              "color": "#ffffff"
            }
          },
          "_name": "features04",
          "_sourceTheme": "neuralm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features04 neuralm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Tag\" name=\"showTag\" checked=\"\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked=\"\">\n        <input type=\"checkbox\" title=\"Card Text\" name=\"showText\">\n        <header>Icon</header>\n        <input type=\"checkbox\" title=\"Card Icon\" name=\"showIcon\">\n        <input type=\"color\" title=\"Icon Gradient 1\" value=\"#386bb7\" name=\"icon_1\" condition=\"showIcon\">\n        <input type=\"color\" title=\"Icon Gradient 2\" value=\"#e24c4a\" name=\"icon_2\" condition=\"showIcon\">\n        <input type=\"color\" title=\"Icon BG\" value=\"#121212\" name=\"iconBg\" condition=\"showIcon\">\n        <header>Buttons</header>\n        <input type=\"checkbox\" title=\"Card Buttons\" name=\"showCardButtons\">\n        <input type=\"color\" title=\"Button Gradient 1\" value=\"#386bb7\" name=\"gradient_1\" condition=\"showCardButtons\" selected=\"\">\n        <input type=\"color\" title=\"Button Gradient 2\" value=\"#e24c4a\" name=\"gradient_2\" condition=\"showCardButtons\" selected=\"\">\n        <input type=\"color\" title=\"Button Active Color\" value=\"#ffffff\" name=\"activeBtn\" condition=\"showCardButtons\" selected=\"\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/neuralm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#6500e0\" selected=\"\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/neuralm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#121212\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6 card\">\n                <div class=\"title-wrapper\" mbr-if=\"showTitle || showTag\">\n                    <h3 class=\"mbr-tag mbr-fonts-style\" data-app-selector=\".mbr-tag\" mbr-theme-style=\"display-2\" mbr-if=\"showTag\"><b>O que você ganha se inscrevendo?</b></h3>\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title, .main-btn\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\">Após a semana de degustação da plataforma, vamos ter um aulão no Zoom sobre como tornar suas aulas mais lucrativas.</h2>\n                </div>\n            </div>\n        </div>\n        <div class=\"row items-wrapper\">\n            <div class=\"item features-without-image col-12 col-lg-3 active\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn, .icon-wrapper\"><b>Acesso gratuito por 7 dias à plataforma Portuguese for You!;</b></h4>\n                        <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\"></p>\n                        <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                            <div class=\"icon-wrap\">\n                                <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-setting mobi-mbri\"></span>\n                            </div>\n                        </div>\n                        <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div><div class=\"item features-without-image col-12 col-lg-3\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn, .icon-wrapper\"><b>Aulas práticas para aplicar no seu dia a dia de profe;</b></h4>\n                        <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\"></p>\n                        <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                            <div class=\"icon-wrap\">\n                                <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-setting mobi-mbri\"></span>\n                            </div>\n                        </div>\n                        <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div><div class=\"item features-without-image col-12 col-lg-3\">\n                <div class=\"item-wrapper\">\n                    <div class=\"item-content\">\n                        <h4 class=\"item-title mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showCardTitle\" data-app-selector=\".item-title, .item-btn, .icon-wrapper\"><b>Grupo exclusivo no WhatsApp para tirar dúvidas (abre todo dia!).</b></h4>\n                        <p class=\"item-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".item-text\"></p>\n                        <div class=\"icon-wrapper icon-card\" mbr-if=\"showIcon\">\n                            <div class=\"icon-wrap\">\n                                <span mbr-icon=\"\" class=\"mbr-iconfont mobi-mbri-setting mobi-mbri\"></span>\n                            </div>\n                        </div>\n                        <div mbr-buttons=\"\" mbr-theme-style=\"display-4\" class=\"mbr-section-btn item-btn\" mbr-if=\"showCardButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-arrow-next mbr-iconfont mbr-iconfont-btn\"></span>\n                                View more\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            \n            \n            \n        </div>\n    </div>\n</section>",
