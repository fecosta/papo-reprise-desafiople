          "_name": "contact01",
          "_sourceTheme": "nichem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"nichem5 contact1\" group=\"Contact\" data-bg-video=\"{{bg.type == 'video'&&bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Color</header>\n        <input type=\"color\" title=\"Color\" name=\"cardColor\" value=\"#f5f5f5\" selected>\n\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#98dee8\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n            <div class=\"title md-pb col-md-12 col-lg-6\">\n                <h2 class=\"mbr-section-title mbr-fonts-style align-left mb-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\"><b>Programação da formação ao vivo</b></h2>\n                <h4 class=\"mbr-section-subtitle align-left mbr-fonts-style mb-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\">Todas as aulas serão às 11 horas da manhã de Brasília</h4>\n     <div class=\"col-12 col-md-12 col-lg-{{imageWidth}} image-wrapper\">\n                <img class=\"w-100\" src=\"@PROJECT_PATH@/assets/images/mbr-1-1076x717.jpg\" alt=\"Mobirise Website Builder\">\n            </div>\n\n                <div class=\"mbr-section-btn align-left mb-4\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a class=\"btn btn-lg btn-primary\" href=\"https://mobiri.se\">LEARN MORE</a>\n                </div>\n            </div>\n\n            <div class=\"col-md-12 col-lg-6\">\n                <div class=\"items\">\n                    <div class=\"card\">\n                        <h3 class=\"mbr-item-title mbr-fonts-style align-left mb-4\" data-app-selector=\".mbr-item-title, .card\" mbr-theme-style=\"display-7\"><b>23/04 <br></b>Como ensinar gramática com contexto</h3>\n                       \n                    </div>\n                    <div class=\"card\">\n                        <h3 class=\"mbr-item-title mbr-fonts-style align-left mb-4\" data-app-selector=\".mbr-item-title, .card\" mbr-theme-style=\"display-7\"><b>24/04</b><br>Como ensinar compreensão oral</h3>\n                        \n                    </div>\n                    <div class=\"card\">\n                        <h3 class=\"mbr-item-title mbr-fonts-style align-left mb-4\" data-app-selector=\".mbr-item-title, .card\" mbr-theme-style=\"display-7\">\n                            <b>27/04</b><br>Como ensinar gêneros discursivos\n                        </h3>\n                      </div>\n                    <div class=\"card mb-0 noborder\">\n                        <h3 class=\"mbr-item-title mbr-fonts-style align-left mb-4\" data-app-selector=\".mbr-item-title, .card\" mbr-theme-style=\"display-7\"><b>29/04<br></b>Como tornar suas aulas de PLE mais lucrativas</h3>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
